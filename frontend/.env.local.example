# PostgreSQL connection string (required)
DATABASE_URL="postgresql://postgres:password@localhost:5432/nepse_dashboard"

# Absolute path to the NEPSE Python project root (where nepse_live.py lives)
# Windows example: D:/new_py/nepse_predict
# Linux/Mac example: /home/user/nepse_predict
NEPSE_ROOT="D:/new_py/nepse_predict"

# Path to the Python executable inside the .venv
# Windows: D:/new_py/nepse_predict/.venv/Scripts/python.exe
# Linux:   D:/new_py/nepse_predict/.venv/bin/python
PYTHON_EXEC="D:/new_py/nepse_predict/.venv/Scripts/python.exe"

# Optional: override base URL for NEPSE external API calls
# NEPSE_API_BASE="https://nepalstock.com.np/api/nots"
